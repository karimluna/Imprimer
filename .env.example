OPENAI_API_KEY=sk-
OPENAI_MODEL=gpt-4o-mini

JUDGE_MODEL=llama3.2:latest # Use a more powerful model for the judge to ensure better evaluation quality
JUDGE_API_KEY=<my-judge-api-key>

OLLAMA_MODEL=qwen2.5:1.5b
OLLAMA_BASE_URL=http://host.docker.internal:11434

IMPRIMER_GATEWAY_URL=http://localhost:8090
EMBEDDER_MODEL=all-MiniLM-L6-v2
HF_TOKEN=<my-hf-token>

# sqlite is used by default, postgresql is used if valid 
USE_POSTGRES=false
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=<my-user>
POSTGRES_PASSWORD=<my-secret-password>
POSTGRES_DB=<my-db>
